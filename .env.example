# Servidor HTTP. 0.0.0.0 publica el panel en todas las interfaces.
FRAGATA_LISTEN_HOST=0.0.0.0
FRAGATA_LISTEN_PORT=8080
# Compatibilidad: FRAGATA_LISTEN tiene prioridad cuando se define.
# FRAGATA_LISTEN=0.0.0.0:8080
FRAGATA_DATA_DIR=./data
FRAGATA_RECORDINGS_DIR=./data/recordings
# Valor inicial para cámaras nuevas. Luego se configura por cámara desde el panel (1m a 24h).
FRAGATA_SEGMENT_DURATION=5m
FRAGATA_SHUTDOWN_TIMEOUT=20s

# Registros locales. Fragata conserva un único archivo y elimina primero
# las líneas antiguas para mantenerlo siempre por debajo de 1 MiB.
FRAGATA_LOG_PATH=./data/logs.txt

# Frecuencia de revisión de la política global de retención.
# Al guardar la política desde el panel también se ejecuta una revisión inmediata.
FRAGATA_RETENTION_INTERVAL=6h

# Login opcional.
# Si falta cualquiera de los dos valores, Fragata no mostrará login.
FRAGATA_ADMIN_USER=
FRAGATA_ADMIN_PASSWORD=
FRAGATA_SESSION_DURATION=720h
# Activar únicamente cuando el panel se publique detrás de HTTPS.
FRAGATA_SECURE_COOKIES=false

# Clave AES-256 opcional en base64 o hex (32 bytes).
# Si se deja vacía, Fragata crea data/secret.key con permisos 0600.
FRAGATA_SECRET_KEY=

# Detección y conectividad de cámaras
FRAGATA_DISCOVERY_TIMEOUT=4s
FRAGATA_PROBE_TIMEOUT=6s
# Puertos TCP que Fragata comprobará antes de probar rutas del diccionario.
FRAGATA_RTSP_PORTS=554,8554,10554,7070,7447,8555,88,80
FRAGATA_RTSP_CONNECT_TIMEOUT=3s
FRAGATA_RTSP_CANDIDATE_TIMEOUT=3s
FRAGATA_RTSP_MAX_CANDIDATES=160
# Diccionario local opcional. Fragata nunca lo descarga de internet.
# Copia config/rtsp-paths.example.txt y agrega rutas particulares.
FRAGATA_RTSP_DICTIONARY=
# Se admiten por defecto IP privadas, IP públicas y dominios/CNAME.
# Cambia a false para restringir la alta a destinos privados/locales.
FRAGATA_ALLOW_PUBLIC_CAMERAS=true
# Separar varios servidores STUN con comas. En LAN normalmente puede quedar vacío.
FRAGATA_STUN_SERVERS=
# Límite global de vistas WebRTC simultáneas.
FRAGATA_MAX_VIEWERS=32
# Detiene FFmpeg/substream cuando no quedan espectadores.
FRAGATA_LIVE_IDLE_TIMEOUT=30s
# Ruta opcional. Si queda vacía, Fragata busca ffmpeg/ffmpeg.exe en PATH.
# FFmpeg solo se usa para normalizar la vista web y convertir AAC a PCMU
# cuando el navegador lo necesita. Las grabaciones conservan el stream original.
FRAGATA_FFMPEG_PATH=

# Subida SFTP heredada mediante entorno.
# Este bloque aparece en el panel como un perfil global de solo lectura.
# También se pueden crear varios servidores SFTP directamente desde
# Configuración > Servidores SFTP y seleccionar uno distinto por cámara.
FRAGATA_SFTP_ENABLED=false
FRAGATA_SFTP_HOST=
FRAGATA_SFTP_PORT=22
FRAGATA_SFTP_USER=
FRAGATA_SFTP_PASSWORD=
FRAGATA_SFTP_PRIVATE_KEY=
FRAGATA_SFTP_KNOWN_HOSTS=./data/known_hosts
FRAGATA_SFTP_REMOTE_DIR=/fragata
FRAGATA_SFTP_WORKERS=1
FRAGATA_SFTP_TIMEOUT=30s
# Solo elimina el MKV local después de confirmar tamaño y renombrado remoto.
FRAGATA_SFTP_DELETE_LOCAL=false
